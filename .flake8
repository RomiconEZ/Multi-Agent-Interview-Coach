[flake8]
max-line-length = 90
extend-ignore = E203,E501,W503,B950
max-complexity = 12
select = B,C,E,F,W,B9
per-file-ignores =
    __init__.py:F401
    tests/*:S101
    src/app/interview/session.py:C901
    src/app/llm/client.py:C901
    src/app/llm/response_parser.py:C901
count = true
statistics = true
show-source = true
